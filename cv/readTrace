#!/usr/bin/env zx
export {};

const test = await fs.readFile('../generalTest.rom', 'utf8');

const code = {};

for (const line of test.split('\n')) {
  if (line === 'v3.0 hex words addressed') continue;
  const l = line.split('#')[0].trim();
  if (l.length === 0) continue;
  const parts = l.split(':');
  if (parts.length === 2) {
    code[parts[0].trim()] = line;
  } else {
    console.error(line);
  }
}

const names = [
  'ClkCn',
  'T',
  'DAddr',
  'DOut',
  'Write',
  'Read',
  'IAddr',
  'Instr',
  'code',
];
const out = [];
const values = Array(names.length).fill('', 0);
let lastClock = 0;
let inside = false;
let rst1 = false;
const trace = await fs.readFile('./trace.txt', 'utf8');

for (const line of trace.split('\n')) {
  const [name, valStr] = line.split(',');
  const valNum = parseInt(valStr, 16);
  if (/F\d+/.test(name)) continue;
  switch (name) {
    case 'RST':
      if (valNum === 1) {
        rst1 = true;
      } else {
        if (rst1 && valNum === 0) {
          inside = true;
        }
      }

      break;
    case 'ClkCn':
      if (inside && valNum !== lastClock) {
        lastClock = valNum;
        out.push(values.concat());
        values.fill('', 0);
      }
      values[names.indexOf(name)] = valNum;
      values[names.indexOf('T')] = valNum % 3;
      break;
    case 'IAddr':
      const padded = valStr.padStart(2, '0');
      if (code[padded]) {
        values[names.indexOf('code')] = code[padded];
        if (rst1 && inside && out.length === 0) {
          code[padded] = null;
          out.push(values.concat());
          values.fill('', 0);
        }
      }
      values[names.indexOf(name)] = padded;
      break;
    case 'Read':
    case 'Write':
      values[names.indexOf(name)] = valNum ? 'X' : '';
      break;

    default:
      if (!names.includes(name)) {
        console.error(line);
      }
      values[names.indexOf(name)] = valStr;
  }
}
await fs.writeFile(
  './trace.csv',
  names.join(',') + '\n' + out.map((values) => values.join(',')).join('\n')
);
await fs.writeFile(
  './trace.html',
  `<html><head><style>
th, td {
  border: thin solid silver;
}

.T0 {
background-color: cyan;
}
.T1 {
background-color: light yellow;
}
.T2 {
background-color: pink;
}
.ClkCn, .T, .DAddr,  .DOut,  .Write,  .Read,  .IAddr,  .Instr {
  text-align: center;
}
.code {
  font-family: monospace;
  white-space: pre;
}
</style></head><body><table>
<colgroup>
${names.map((name) => `<col class="${name}" />`).join('\n')}
</colgroup>
<thead>
<tr>${names.map((name) => `<th>${name}</th>`).join('')}</tr>
</thead>
<tbody>
${out.map((row) => `<tr class="T${row[1]}">${row.map((val, index) => `<td class="${names[index]}">${val}</td>`).join('')}</tr>`).join('\n')}
</tbody></table></body></html>`
);
